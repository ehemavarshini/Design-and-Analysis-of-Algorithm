#include<iostream>
#include<string>
#include<vector>
using namespace std;
#define MAX_CHARS 256
void precomputeShiftTable(const string& pattern,int shiftTable[MAX_CHARS]){
int m=pattern.length();
for(int i=0;i<MAX_CHARS;i++){
shiftTable[i]=m;
}
for(int j=0;j<m-1;j++){
shiftTable[(unsigned char)pattern[j]]=m-1-j;
}
}
int horspoolSearch(const string& text,const string& pattern){
int n=text.length();
int m=pattern.length();
int shiftTable[MAX_CHARS];
if(m>n)return -1;
precomputeShiftTable(pattern,shiftTable);
int skip=0;
while(skip<=n-m){
int j=m-1;
while(j>=0&&text[skip+j]==pattern[j]){
j--;
}
if(j<0){
return skip;
}
unsigned char badChar=text[skip+m-1];
skip+=shiftTable[badChar];
}
return -1;
}
int main(){
string text,pattern;
cout<<"Enter text: ";
getline(cin,text);
cout<<"Enter pattern: ";
getline(cin,pattern);
int result=horspoolSearch(text,pattern);
if(result!=-1){
cout<<"Pattern found at index: "<<result<<endl;
}else{
cout<<"Pattern not found"<<endl;
}
return 0;
}
