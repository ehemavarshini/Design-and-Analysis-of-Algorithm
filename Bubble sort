#include<iostream>
using namespace std;
int main()
{
   int n,temp;
   cout<<"enter no of elements:";
   cin>>n;
   int a[n];
   cout<<"enter elements:\n";
   for(int i=0;i<n;i++)
   {
      cin>>a[i];
   }
   for(int i=0;i<n-1;i++)
   {
      bool flag=false;
      for(int j=0;j<n-1-i;j++)
      {
         if(a[j]>a[j+1])
         {
            temp=a[j];
            a[j]=a[j+1];
            a[j+1]=temp;
            flag=true;
         }
      }
         if(!flag)
            break;

   }
   cout<<"sorted array using bubble sort:\n";
   for(int i=0;i<n;i++)
   {
      cout<<a[i]<<"\t";
   }
   cout<<"\n";
   return 0;
}
