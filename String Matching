#include <iostream>
#include <string>
using namespace std;
int main() {
    string T, P;
    int n = 0, m = 0;
    cout << "Enter string text: ";
    getline(cin, T);
    cout << "Enter pattern: ";
    getline(cin, P);
    while (T[n] != '\0') {
        n++;
    }
    while (P[m] != '\0') {
        m++;
    }
    bool found = false;
    for (int i = 0; i <= n - m; i++) {
        int j = 0;
        while (j < m && T[i + j] == P[j]) {
            j++;
        }

        if (j == m) {
            cout << "Pattern found at index: " << i << endl;
            found = true;
            break;
        }
    }

    if (!found) {
        cout << "Pattern is not found in the text" << endl;
    }

    return 0;
}
