#include <iostream>
#include <algorithm> 

using namespace std;

int main() {
    int n;
    cout << "Enter number of vertices: ";
    cin >> n;
    int D[10][10];

    cout << "Enter the adjacency matrix (use 999 for infinity):\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> D[i][j];
        }
    }

    // The Core Floyd-Warshall Logic
    for (int k = 0; k < n; k++) {
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                // Update shortest path using vertex 'k' as a bridge
                if (D[i][k] + D[k][j] < D[i][j]) {
                    D[i][j] = D[i][k] + D[k][j];
                }
            }
        }
    }

    // Check for negative cycles
    for (int i = 0; i < n; i++) {
        if (D[i][i] < 0) {
            cout << "Negative cycle detected!" << endl;
            return 0;
        }
    }
     cout << "\nShortest path matrix:\n";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (D[i][j] == 999) cout << "INF\t";
            else cout << D[i][j] << "\t";
        }
        cout << endl;
    }

    return 0;
}
