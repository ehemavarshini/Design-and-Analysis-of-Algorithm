#include<iostream>
using namespace std;
int main(){
   int n=5,temp,min;
   int a[5]={20,30,10,50,40};
   for(int i=0;i<n-1;i++){
      min=i;
      for(int j=i+1;j<n;j++){
         if(a[j] < a[min]){
            min=j;
         }
      }
      temp=a[i];
      a[i]=a[min];
      a[min]=temp;
   }
   for(int i=0;i<n;i++){
      cout<<"sorted numbers:"<<a[i]<<endl;
   }
}
