#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;
int main() {
    int n, i, j;
    float x[20], y[20];
    float d, dist;
    int p1 = 0, p2 = 1;
    cout << "Enter no of points (n >= 2): ";
    if (!(cin >> n) || n < 2) {
        cout << "Invalid input. Please enter n >= 2." << endl;
        return 1;
    }
    for (i = 0; i < n; i++) {
        cout << "Enter x" << i + 1 << " and y" << i + 1 << ": ";
        cin >> x[i] >> y[i];
    }
    d = sqrt(pow(x[0] - x[1], 2) + pow(y[0] - y[1], 2));
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1; j < n; j++) {
            dist = sqrt(pow(x[i] - x[j], 2) + pow(y[i] - y[j], 2));
            if (dist < d) {
                d = dist;
                p1 = i;
                p2 = j;
            }
        }
    }
    cout << "\nClosest pair of points:\n";
    cout << "p" << p1 + 1 << "(" << x[p1] << "," << y[p1] << ") and "
         << "p" << p2 + 1 << "(" << x[p2] << "," << y[p2] << ")\n";
    cout << "Minimum distance: " << fixed << setprecision(4) << d << endl;
    return 0;
}
